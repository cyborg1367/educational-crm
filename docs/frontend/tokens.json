{
  "$description": "Educational CRM — Design Tokens. Primitive tokens feed semantic tokens. Components (Phase 6) consume semantic tokens only. Source of truth — see 03-design-tokens.md for rationale.",
  "$version": "1.2.0",

  "primitive": {
    "color": {
      "neutral": {
        "50": "#FAFAF9", "100": "#F5F5F4", "200": "#E7E5E4", "300": "#D6D3D1",
        "400": "#A8A29E", "500": "#78716C", "600": "#57534E", "700": "#44403C",
        "800": "#292524", "900": "#1A1A1A"
      },
      "brand": {
        "50": "#FEF5EE", "100": "#FCE8D8", "200": "#F8CEB1", "300": "#F3B38A",
        "400": "#EE9A5E", "500": "#E87722", "600": "#D0691D", "700": "#B85B19",
        "800": "#9F4D14", "900": "#863F10"
      },
      "green": {
        "50": "#F0FDF4", "100": "#DCFCE7", "300": "#86EFAC", "500": "#22C55E",
        "600": "#16A34A", "700": "#15803D"
      },
      "amber": {
        "50": "#FFFBEB", "100": "#FEF3C7", "300": "#FCD34D", "500": "#F59E0B",
        "600": "#D97706", "700": "#B45309"
      },
      "red": {
        "50": "#FEF2F2", "100": "#FEE2E2", "300": "#FCA5A5", "500": "#EF4444",
        "600": "#DC2626", "700": "#B91C1C"
      },
      "blue": {
        "50": "#EFF6FF", "100": "#DBEAFE", "300": "#93C5FD", "500": "#3B82F6",
        "600": "#2563EB", "700": "#1D4ED8"
      }
    },
    "font": {
      "family": {
        "base": "'Vazirmatn', Tahoma, sans-serif"
      },
      "size": {
        "xs": "11px", "sm": "13px", "base": "14px",
        "lg": "15px", "xl": "20px", "2xl": "27px"
      },
      "lineHeight": {
        "xs": "1.5", "sm": "1.5", "base": "1.6",
        "lg": "1.6", "xl": "1.4", "2xl": "1.25"
      },
      "weight": {
        "regular": "400", "medium": "500", "semibold": "600", "bold": "700"
      }
    },
    "space": {
      "0": "0px", "1": "4px", "2": "7px", "3": "11px", "4": "14px",
      "5": "18px", "6": "22px", "8": "29px", "10": "36px", "12": "43px", "16": "58px"
    },
    "radius": {
      "sm": "5px", "md": "9px", "lg": "13px", "xl": "16px", "full": "9999px"
    },
    "elevation": {
      "0": "none",
      "1": "0 1px 2px rgba(26,26,26,0.04), 0 1px 3px rgba(26,26,26,0.06)",
      "2": "0 4px 6px -1px rgba(26,26,26,0.06), 0 2px 4px -2px rgba(26,26,26,0.04)",
      "3": "0 12px 24px -4px rgba(26,26,26,0.08), 0 8px 16px -6px rgba(26,26,26,0.04)"
    },
    "motion": {
      "duration": { "fast": "120ms", "base": "200ms", "slow": "320ms" },
      "easing": { "standard": "cubic-bezier(0.4, 0, 0.2, 1)" }
    },
    "zIndex": {
      "dropdown": 10, "drawer": 20, "popover": 35, "modal": 30, "toast": 40
    }
  },

  "semantic": {
    "color": {
      "text": {
        "primary": "{primitive.color.neutral.900}",
        "secondary": "{primitive.color.neutral.600}",
        "disabled": "{primitive.color.neutral.400}",
        "inverse": "#FFFFFF",
        "link": "{primitive.color.brand.600}"
      },
      "surface": {
        "page": "{primitive.color.neutral.50}",
        "card": "#FFFFFF",
        "subtle": "{primitive.color.neutral.100}",
        "border": "{primitive.color.neutral.200}",
        "danger-subtle": "{primitive.color.red.50}",
        "warning-subtle": "{primitive.color.amber.50}"
      },
      "action": {
        "primary": "{primitive.color.brand.500}",
        "primaryHover": "{primitive.color.brand.600}",
        "focusRing": "{primitive.color.brand.400}"
      },
      "status": {
        "neutral": "{primitive.color.neutral.500}",
        "neutral-muted": "{primitive.color.neutral.400}",
        "info": "{primitive.color.blue.600}",
        "success": "{primitive.color.green.600}",
        "success-muted": "{primitive.color.green.500}",
        "warning": "{primitive.color.amber.600}",
        "warning-muted": "{primitive.color.amber.500}",
        "danger": "{primitive.color.red.600}",
        "danger-strong": "{primitive.color.red.700}",
        "brand-muted": "{primitive.color.brand.400}"
      }
    },
    "statusMap": {
      "$description": "Backend enum value -> semantic status color token. Mirrors 03-design-tokens.md §1.2.",
      "person.prospect": "color.status.neutral",
      "person.lead": "color.status.info",
      "person.student": "color.status.success",
      "person.dormant": "color.status.warning-muted",
      "person.alumni": "color.status.brand-muted",
      "enrollment.pre_enroll": "color.status.info",
      "enrollment.active": "color.status.success",
      "enrollment.completed": "color.status.success-muted",
      "enrollment.dropped": "color.status.danger-strong",
      "invoice.open": "color.status.neutral",
      "invoice.partially_paid": "color.status.warning",
      "invoice.paid": "color.status.success",
      "installment.pending": "color.status.neutral",
      "installment.partially_paid": "color.status.warning",
      "installment.paid": "color.status.success",
      "installment.overdue": "color.status.danger",
      "installment.cancelled": "color.status.neutral-muted",
      "task.open": "color.status.neutral",
      "task.done": "color.status.success-muted",
      "task.cancelled": "color.status.neutral-muted",
      "class.planned": "color.status.neutral",
      "class.active": "color.status.success",
      "class.completed": "color.status.success-muted",
      "class.cancelled": "color.status.neutral-muted",
      "journey.active": "color.status.success",
      "journey.completed": "color.status.success-muted"
    },
    "confirmationTier": {
      "tier2": {
        "accent": "{primitive.color.amber.500}",
        "surface": "{semantic.color.surface.card}"
      },
      "tier3": {
        "accent": "{primitive.color.red.700}",
        "surface": "{semantic.color.surface.danger-subtle}",
        "elevation": "{primitive.elevation.3}"
      }
    },
    "space": {
      "cardPadding": "{primitive.space.5}",
      "sectionGap": "{primitive.space.8}",
      "inlineGap": "{primitive.space.2}",
      "pageMargin": "{primitive.space.10}"
    }
  },

  "locale": {
    "calendar": "jalali",
    "calendarStorage": "gregorian",
    "digitsDisplay": "persian",
    "digitsInput": "normalize-both",
    "currencyUnit": "toman",
    "currencyDecimal": false,
    "direction": "rtl"
  }
}
